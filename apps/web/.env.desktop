# Desktop (offline Tauri) build. The web bundle talks to the local sidecar on
# loopback, not the cloud. Supabase vars are present only so the client
# constructs without throwing — offline auth never calls Supabase (see
# lib/offlineMode.ts / AuthContext.signInOffline).
VITE_API_URL=http://127.0.0.1:3010/api/v1
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=offline-unused
VITE_UI_PREVIEW=false
